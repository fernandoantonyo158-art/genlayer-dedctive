# ── GenLayer Detective — Environment Variables ──────────────────────────────
# Copy this file to .env.local and fill in values before running locally.
# NEVER commit .env.local to git.

# HMAC secret for server-side answer token signing (use a long random string)
VERIFY_SECRET=replace-with-long-random-secret

# Case answers (only read server-side — never exposed to the browser)
ANSWER_CASE01_SOLUTION=REDACTED
ANSWER_CASE02_SUSPECT=REDACTED
ANSWER_CASE02_KILLER=REDACTED

# GenLayer Bradbury Testnet RPC (optional override)
NEXT_PUBLIC_GENLAYER_RPC=https://rpc-bradbury.genlayer.com
NEXT_PUBLIC_GENLAYER_CHAIN_ID=4221

# Contract address (public — safe as NEXT_PUBLIC_)
NEXT_PUBLIC_CONTRACT_ADDRESS=0x868ef59CBA2857bD930F3849E0d3Fdb001F914Fa
